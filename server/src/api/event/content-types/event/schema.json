        "Publishing Ministries",
        "Adventist-laymen's Services & Industries",
        "Ministerial Secretary",
        "Spirit of Prophecy",
        "Children & Adolescent Ministries",
        "Men's Ministries",
        "Sabbath School",
        "Communications",
        "Public affairs & Religious Liberty",
        "Stewardship Ministries ",
        "Community Services",
        "Public Campus Ministries",
        "Woman's Ministries ",
        "Education",
        "Planned Giving and Trust Services",
        "Youth Ministries ",
        "Spiritual Growth",
        "Discipleship",
        "Bible Knowledge",
        "Apologetics & Doctrine",
        "Leadership Development",
        "Fellowship & Social",
        "Community Outreach",
        "Evangelism & Mission",
        "Health & Lifestyle",
        "Life Skills & Career Development",
        "Creative Arts & Talents",
        "Recreation & Sports",
        "Stewardship & Service",
        "Identity & Purpose",
        "Technology & Media Ministry",
        "Adventist Heritage & Beliefs"
